---
import { getCollection, render } from "astro:content";

import config from "virtual:astro-content-collections-minimal/config";
import Layout from "virtual:astro-content-collections-minimal/components/Layout";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages.map((page) => ({
    params: { id: page.id === "index" ? undefined : page.id },
    props: { page },
  }));
}

const { siteTitle } = config;

const { page } = Astro.props;
const { Content } = await render(page);

const pageTitle =
  page.id === "index" || !page.data.title
    ? siteTitle
    : `${page.data.title} | ${siteTitle}`;
---

<Layout title={pageTitle}>
  <Content />
</Layout>
