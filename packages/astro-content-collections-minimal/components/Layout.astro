---
import config from "virtual:astro-content-collections-minimal/config";
import "virtual:astro-content-collections-minimal/styles";

import Header from "./Header.astro";
import Footer from "./Footer.astro";

const { siteTitle, siteDescription, lang } = config;

const { title = siteTitle, description = siteDescription } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body
    class="prose prose-sm mx-auto flex min-h-svh max-w-4xl flex-col bg-(--color-background) p-6"
  >
    <Header />
    <main class="grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
